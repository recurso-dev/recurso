# Recurso Environment Configuration
# Copy this file to .env and fill in your values.
#
# REQUIRED  = the API will not start (or a core feature is broken) without it.
# Everything else is optional — unset values fall back to safe defaults or
# mock implementations (mock payment gateway, console email/SMS, etc.).

# ============================================================
# Core
# ============================================================

# development | production
APP_ENV=development

# Port the API listens on (default: 8080)
PORT=8080

# Public base URL of the API — used in emails, hosted checkout links, etc.
BASE_URL=http://localhost:8080

# Public base URL of the customer portal (default: BASE_URL)
# PORTAL_URL=http://localhost:8080

# Public base URL of the admin dashboard SPA (default: BASE_URL). Password-reset
# emails link to {DASHBOARD_URL}/reset-password?token=...
# DASHBOARD_URL=http://localhost:5173

# Allowed CORS origin for browser clients (e.g. the frontend dev server)
# CORS_ORIGIN=http://localhost:5173

# Dev auth bypass — NEVER enable in production
# ALLOW_DEV_BYPASS=true

# Dashboard user session lifetime, in hours (default: 168 = 7 days). Controls
# both the server-side session expiry and the recurso_session cookie max-age.
# SESSION_TTL_HOURS=168

# ============================================================
# Social login (OAuth) + SAML SSO  (admin-dashboard auth, Phase 3)
# ============================================================

# Native OAuth social login. A provider's buttons only appear (GET
# /auth/oauth/providers reports it enabled) when BOTH its id and secret are set.
# Configure the provider's redirect/callback URL as
#   {OAUTH_REDIRECT_BASE_URL}/auth/oauth/{google|github}/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Public base URL of THIS API, used to build the OAuth redirect/callback URLs
# and the per-tenant SAML SP metadata/ACS URLs (default: BASE_URL).
# OAUTH_REDIRECT_BASE_URL=http://localhost:8080

# Secret (any string) that signs the short-lived OAuth state+PKCE cookie. If
# unset, a random per-boot secret is used (logins in flight across a restart
# then safely fail to the login error page). Also reused by the accounting
# integrations below. Set a stable value in production.
# OAUTH_STATE_SECRET=

# SAML SSO Service Provider signing key + certificate (PEM). If either is unset
# an ephemeral self-signed pair is generated at boot — fine for bringing the SP
# up and rendering metadata, but set a STABLE pair before certifying against a
# real IdP (otherwise the SP cert changes on every restart). Per-tenant IdP
# config is stored in the DB via PUT /v1/sso/connection, not here.
# SAML_SP_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# SAML_SP_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# ============================================================
# Database & storage
# ============================================================

# REQUIRED: PostgreSQL connection string (migrations run automatically on boot)
DATABASE_URL=postgres://user:password@localhost:5432/recurso?sslmode=disable

# Redis — distributed scheduler lock + idempotency store. REQUIRED for any
# multi-instance deployment: without it the app uses a no-op locker and a
# per-instance in-memory store, so schedulers can run concurrently and money
# paths (mandate debit, trial conversion) risk running twice (ENG-161). The
# local docker-compose stack wires this automatically.
# REDIS_URL=redis://localhost:6379
# Set REQUIRE_REDIS=true in multi-instance/prod so the app refuses to start on
# the unsafe in-memory fallback instead of degrading silently. Only enable it
# once REDIS_URL points at a reachable Redis.
# REQUIRE_REDIS=false

# TigerBeetle ledger (optional; falls back to Postgres-only ledger if unreachable)
# TIGERBEETLE_ADDRESS=127.0.0.1:3001

# ============================================================
# Payments
# ============================================================
# Leave both gateways unset to use the built-in mock gateway (dev/testing).

# Stripe
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Publishable key — handed to the browser to mount the checkout Payment Element
# (card + ACH). Safe to expose. Required for real self-serve Stripe checkout.
# STRIPE_PUBLISHABLE_KEY=pk_test_...

# Razorpay
# RAZORPAY_KEY_ID=rzp_test_...
# RAZORPAY_KEY_SECRET=...
# RAZORPAY_WEBHOOK_SECRET=...

# Smart retry strategy for dunning: epsilon_greedy | thompson_sampling | ucb1
# DUNNING_STRATEGY=epsilon_greedy

# ============================================================
# Email / SMS
# ============================================================
# Leave SMTP_HOST unset to log emails to the console instead of sending.

# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@recurso.dev
# SMTP_FROM_NAME=Recurso
# SMTP_USE_TLS=true

# Twilio SMS (leave unset for console SMS mock)
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+1...

# ============================================================
# Tax / E-invoicing (India)
# ============================================================

# Company location used by the tax engine (defaults: IN / TN)
# COMPANY_COUNTRY=IN
# COMPANY_STATE=TN

# TaxJar — real US sales-tax rates (leave unset to keep the US engine as a
# 0% stub; invoices are then marked sales_tax_stub). Rates are cached
# in-memory for 24h per buyer (state, zip) to control API spend.
# TAXJAR_API_KEY=
# TAXJAR_API_URL=https://api.sandbox.taxjar.com   # sandbox; default is https://api.taxjar.com

# VIES EU VAT-number validation — leave disabled to keep intra-EU cross-border
# B2B reverse charge presence-based (any VAT number present -> reverse charge).
# When enabled, the buyer's VAT number is validated against the EU VIES service
# before reverse charge is granted; an invalid number falls back to charging
# VAT, and a VIES outage degrades to the presence-based behaviour (never fails
# an invoice). Enable with VIES_ENABLED=true, or implicitly by setting
# VIES_API_URL (e.g. to point tests at a stub). Default endpoint is the EC REST
# API at https://ec.europa.eu/taxation_customs/vies/rest-api (no key required).
# VIES_ENABLED=true
# VIES_API_URL=https://ec.europa.eu/taxation_customs/vies/rest-api

# NIC IRP e-invoicing — leave unset to use the mock GSP adapter
# NIC_PRIVATE_KEY_PATH=/path/to/nic_private_key.pem
# NIC_ENVIRONMENT=sandbox   # sandbox | production

# Invoice PDF letterhead
# PDF_COMPANY_NAME=Your Company Name
# PDF_COMPANY_ADDRESS=123 Business Street, City, State - 000000
# PDF_COMPANY_GSTIN=
# PDF_COMPANY_PAN=
# PDF_COMPANY_STATE=
# Seller country selects the invoice layout: IN = India GST tax invoice
# (GSTIN, HSN, CGST/SGST/IGST); anything else = a plain invoice (single tax
# line, seller tax id, no HSN). Defaults to COMPANY_COUNTRY.
# PDF_COMPANY_COUNTRY=US
# Non-GST seller tax id shown on non-India invoices (e.g. a US EIN).
# PDF_COMPANY_TAX_ID=12-3456789
# PDF_BANK_DETAILS=Bank: HDFC Bank\nAccount: 00000000000000\nIFSC: HDFC0000000

# ============================================================
# Accounting integrations (QuickBooks / Xero)
# ============================================================

# Public base URL used to build OAuth redirect URIs
# APP_BASE_URL=http://localhost:8080

# Secret for signing OAuth state tokens (recommended if integrations enabled)
# OAUTH_STATE_SECRET=

# QuickBooks Online
# QBO_CLIENT_ID=
# QBO_CLIENT_SECRET=

# Xero
# XERO_CLIENT_ID=
# XERO_CLIENT_SECRET=

# ============================================================
# AI
# ============================================================

# REQUIRED for GenAI analytics & smart dunning copy; unset disables AI features
# OPENAI_API_KEY=sk-...
# GenAI analytics (POST /v1/analytics/ask) is enabled only when this is set.
# LLM-generated SQL runs under a restricted genai_readonly role that can read
# only tenant-scoped views (migration 000077) — isolation is enforced by the
# database, not the prompt.

# ============================================================
# Observability / Alerting
# ============================================================
# See docs/incident-runbook.md for how alerts fit into incident response.

# Webhook that receives operational alerts (component up/down transitions
# detected by the built-in health watcher, checked every 60s). Unset = alerting
# disabled (no-op). Point this at any HTTP endpoint — or a Slack incoming
# webhook together with ALERT_WEBHOOK_FORMAT=slack.
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/XXXX

# Payload format: json (default) | slack
#   json  -> {"severity","title","body","source":"recurso","timestamp"}
#   slack -> {"text":"[SEVERITY] title — body"}  (Slack incoming webhooks)
# ALERT_WEBHOOK_FORMAT=json

# ============================================================
# Anonymous telemetry (opt-in)
# ============================================================
# OFF by default: unset = zero network calls, zero data written. Enable to
# help the maintainers measure how many self-hosted instances reach their
# first real invoice. Only anonymous, bucketed, non-PII signals are sent —
# see docs/telemetry.md for exactly what is (and is never) transmitted.

# Set to exactly "true" to opt in. Anything else keeps telemetry disabled.
# TELEMETRY_OPTIN=true

# Where events are POSTed (default: https://telemetry.recurso.dev/v1/events).
# Point this at your own server to verify what is sent.
# TELEMETRY_ENDPOINT=https://telemetry.recurso.dev/v1/events

# ============================================================
# Misc
# ============================================================

# Open Exchange Rates app id for live FX rates (unset = static built-in rates)
# OPENEXCHANGERATES_APP_ID=

# ============================================================
# Docker Compose only
# ============================================================
# Read by docker-compose(.prod).yml, not by the API binary itself.

# REQUIRED for docker-compose.prod.yml: Postgres container credentials
# (DATABASE_URL is derived from these inside the compose file)
POSTGRES_USER=recurso
POSTGRES_PASSWORD=changeme
POSTGRES_DB=recurso

# REQUIRED for docker-compose.prod.yml: passed to the api container
API_SECRET=changeme

# Frontend build args (docker-compose.prod.yml). Leave VITE_API_BASE_URL empty
# so the SPA uses relative paths and nginx proxies API calls to the api service.
# VITE_API_BASE_URL=

# Reporting currency for FX-normalized MRR analytics (tenant BaseCurrency wins when set)
REPORTING_CURRENCY=USD
