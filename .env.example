# Recurso Environment Configuration
# Copy this file to .env and fill in your values.
#
# REQUIRED  = the API will not start (or a core feature is broken) without it.
# Everything else is optional — unset values fall back to safe defaults or
# mock implementations (mock payment gateway, console email/SMS, etc.).

# ============================================================
# Core
# ============================================================

# development | production
APP_ENV=development

# Port the API listens on (default: 8080)
PORT=8080

# Public base URL of the API — used in emails, hosted checkout links, etc.
BASE_URL=http://localhost:8080

# Public base URL of the customer portal (default: BASE_URL)
# PORTAL_URL=http://localhost:8080

# Allowed CORS origin for browser clients (e.g. the frontend dev server)
# CORS_ORIGIN=http://localhost:5173

# Dev auth bypass — NEVER enable in production
# ALLOW_DEV_BYPASS=true

# ============================================================
# Database & storage
# ============================================================

# REQUIRED: PostgreSQL connection string (migrations run automatically on boot)
DATABASE_URL=postgres://user:password@localhost:5432/recurso?sslmode=disable

# Redis — enables rate limiting, distributed locking, idempotency (recommended in prod)
# REDIS_URL=redis://localhost:6379

# TigerBeetle ledger (optional; falls back to Postgres-only ledger if unreachable)
# TIGERBEETLE_ADDRESS=127.0.0.1:3001

# ============================================================
# Payments
# ============================================================
# Leave both gateways unset to use the built-in mock gateway (dev/testing).

# Stripe
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Razorpay
# RAZORPAY_KEY_ID=rzp_test_...
# RAZORPAY_KEY_SECRET=...
# RAZORPAY_WEBHOOK_SECRET=...

# Smart retry strategy for dunning: epsilon_greedy | thompson_sampling | ucb1
# DUNNING_STRATEGY=epsilon_greedy

# ============================================================
# Email / SMS
# ============================================================
# Leave SMTP_HOST unset to log emails to the console instead of sending.

# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@recurso.dev
# SMTP_FROM_NAME=Recurso
# SMTP_USE_TLS=true

# Twilio SMS (leave unset for console SMS mock)
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+1...

# ============================================================
# Tax / E-invoicing (India)
# ============================================================

# Company location used by the tax engine (defaults: IN / TN)
# COMPANY_COUNTRY=IN
# COMPANY_STATE=TN

# TaxJar — real US sales-tax rates (leave unset to keep the US engine as a
# 0% stub; invoices are then marked sales_tax_stub). Rates are cached
# in-memory for 24h per buyer (state, zip) to control API spend.
# TAXJAR_API_KEY=
# TAXJAR_API_URL=https://api.sandbox.taxjar.com   # sandbox; default is https://api.taxjar.com

# NIC IRP e-invoicing — leave unset to use the mock GSP adapter
# NIC_PRIVATE_KEY_PATH=/path/to/nic_private_key.pem
# NIC_ENVIRONMENT=sandbox   # sandbox | production

# Invoice PDF letterhead
# PDF_COMPANY_NAME=Your Company Name
# PDF_COMPANY_ADDRESS=123 Business Street, City, State - 000000
# PDF_COMPANY_GSTIN=
# PDF_COMPANY_PAN=
# PDF_COMPANY_STATE=
# PDF_BANK_DETAILS=Bank: HDFC Bank\nAccount: 00000000000000\nIFSC: HDFC0000000

# ============================================================
# Accounting integrations (QuickBooks / Xero)
# ============================================================

# Public base URL used to build OAuth redirect URIs
# APP_BASE_URL=http://localhost:8080

# Secret for signing OAuth state tokens (recommended if integrations enabled)
# OAUTH_STATE_SECRET=

# QuickBooks Online
# QBO_CLIENT_ID=
# QBO_CLIENT_SECRET=

# Xero
# XERO_CLIENT_ID=
# XERO_CLIENT_SECRET=

# ============================================================
# AI
# ============================================================

# REQUIRED for GenAI analytics & smart dunning copy; unset disables AI features
# OPENAI_API_KEY=sk-...

# ============================================================
# Observability / Alerting
# ============================================================
# See docs/incident-runbook.md for how alerts fit into incident response.

# Webhook that receives operational alerts (component up/down transitions
# detected by the built-in health watcher, checked every 60s). Unset = alerting
# disabled (no-op). Point this at any HTTP endpoint — or a Slack incoming
# webhook together with ALERT_WEBHOOK_FORMAT=slack.
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/XXXX

# Payload format: json (default) | slack
#   json  -> {"severity","title","body","source":"recurso","timestamp"}
#   slack -> {"text":"[SEVERITY] title — body"}  (Slack incoming webhooks)
# ALERT_WEBHOOK_FORMAT=json

# ============================================================
# Misc
# ============================================================

# Open Exchange Rates app id for live FX rates (unset = static built-in rates)
# OPENEXCHANGERATES_APP_ID=

# ============================================================
# Docker Compose only
# ============================================================
# Read by docker-compose(.prod).yml, not by the API binary itself.

# REQUIRED for docker-compose.prod.yml: Postgres container credentials
# (DATABASE_URL is derived from these inside the compose file)
POSTGRES_USER=recurso
POSTGRES_PASSWORD=changeme
POSTGRES_DB=recurso

# REQUIRED for docker-compose.prod.yml: passed to the api container
API_SECRET=changeme

# Frontend build args (docker-compose.prod.yml). Leave VITE_API_BASE_URL empty
# so the SPA uses relative paths and nginx proxies API calls to the api service.
# VITE_API_BASE_URL=

# Reporting currency for FX-normalized MRR analytics (tenant BaseCurrency wins when set)
REPORTING_CURRENCY=USD
