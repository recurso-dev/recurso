# Recurso Environment Configuration
# Copy this file to .env and fill in your values

# === REQUIRED ===

# Database
DATABASE_URL=postgres://user:password@localhost:5432/recurso?sslmode=disable
POSTGRES_USER=user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=recurso

# Application
APP_ENV=development  # development | production
PORT=8080

# === OPTIONAL ===

# Redis (required for rate limiting, distributed locking, idempotency)
# REDIS_URL=redis://localhost:6379

# CORS
# CORS_ORIGIN=http://localhost:5173

# Stripe (leave unset to use mock gateway)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Razorpay (leave unset to use mock gateway)
# RAZORPAY_KEY_ID=rzp_test_...
# RAZORPAY_KEY_SECRET=...

# Email / SMTP (leave unset for console notifier)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@recurso.dev

# OpenAI (required for GenAI analytics)
# OPENAI_API_KEY=sk-...

# Dev bypass (NEVER enable in production)
# ALLOW_DEV_BYPASS=true
