#!/bin/sh
# Recurso pre-commit hook: gofmt + golangci-lint on staged Go changes.
# Install with: make hooks

# Staged Go files (added / copied / modified — not deletions).
gofiles=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)
[ -z "$gofiles" ] && exit 0

# 1. gofmt — reject anything not formatted.
unformatted=$(gofmt -l $gofiles)
if [ -n "$unformatted" ]; then
  echo "✗ gofmt: these staged files are not formatted:"
  echo "$unformatted" | sed 's/^/    /'
  echo "  Fix with: gofmt -w <files>   (or: make fmt)"
  exit 1
fi

# 2. golangci-lint — lint only the packages touched by staged files (fast).
GCL=$(command -v golangci-lint 2>/dev/null || echo "$(go env GOPATH)/bin/golangci-lint")
if [ ! -x "$GCL" ]; then
  echo "⚠ golangci-lint not found — skipping lint (install: https://golangci-lint.run)."
  echo "✓ gofmt passed"
  exit 0
fi

# Resolve each staged file to (module_root|package_dir_relative_to_module) so
# nested modules (e.g. sdk/go) are linted from their own root — golangci-lint
# can't typecheck a package that lives outside the module it's invoked in.
resolve() {
  d=$(dirname "$1")
  m="$d"
  while [ "$m" != "." ] && [ ! -f "$m/go.mod" ]; do m=$(dirname "$m"); done
  if [ "$d" = "$m" ]; then rel="."
  elif [ "$m" = "." ]; then rel="./$d"
  else rel="./${d#"$m"/}"; fi
  echo "$m|$rel"
}

pairs=$(for f in $gofiles; do resolve "$f"; done | sort -u)
fail=0
for m in $(echo "$pairs" | cut -d'|' -f1 | sort -u); do
  pkgs=$(echo "$pairs" | grep "^$m|" | cut -d'|' -f2 | sort -u)
  echo "golangci-lint in '${m}' on: $(echo $pkgs)"
  if ! ( cd "$m" && "$GCL" run $pkgs ); then fail=1; fi
done
if [ "$fail" -eq 1 ]; then
  echo "✗ golangci-lint found issues. Commit aborted."
  exit 1
fi

echo "✓ pre-commit checks passed"
