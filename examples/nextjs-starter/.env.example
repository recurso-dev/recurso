# Base URL of your Recurso API.
# For the local `make demo` stack this is http://localhost:8080
RECURSO_API_URL=http://localhost:8080

# Secret API key. SERVER-SIDE ONLY — never prefix this with NEXT_PUBLIC_ and
# never reference it from a client component. All Recurso calls in this app go
# through server components / route handlers so the key never reaches the
# browser.
#
# The demo seed (`make demo`) provisions this test key:
RECURSO_API_KEY=sk_test_12345
